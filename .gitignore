# ── Python bytecode ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
.env

# ── Data files — large CSVs regenerated by fetch_top6_data.py ────────────────
# Raw downloads (can be 25+ MB each) — keep .gitkeep for directory skeleton
data/sports/raw/*
!data/sports/raw/.gitkeep
# Processed outputs: CSVs are committed so Streamlit Cloud can serve the app
# without requiring a runtime data-fetch step on every cold start.
data/sports/processed/*
!data/sports/processed/.gitkeep
!data/sports/processed/*.csv
!data/sports/processed/*.json
# Bet output files (generated per run)
data/sports/outputs/*
!data/sports/outputs/.gitkeep
# Duplicate data mirror inside sports_betting/
sports_betting/data/

# ── User-specific external data (injuries, lineups, etc.) ────────────────────
# Keep the folder + README but ignore actual CSV uploads
data/sports/external/*.csv

# ── Claude local settings (machine-specific) ─────────────────────────────────
.claude/settings.local.json

# ── OS / editor artefacts ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Secrets / credentials ─────────────────────────────────────────────────────
*.env
secrets.toml
.streamlit/secrets.toml
.claude/
